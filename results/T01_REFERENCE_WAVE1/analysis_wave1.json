  "properties": [
    {
      "id": "N1",
      "name": "synchronous_exclusion_bound",
      "statement": "If at time t every site has neighbor-sum >= theta, then at t+1 the configuration is identically zero (global extinction in one step).",
      "class": "NECESSARY",
      "justification": "By transition rule: ns >= theta forces x_i^{t+1}=0 for all i, independent of births."
    },
    {
      "id": "N2",
      "name": "isolation_preserves_or_birth",
      "statement": "If a site has neighbor-sum < theta and is occupied, it remains occupied (births irrelevant for that site).",
      "class": "NECESSARY",
      "justification": "Rule branch: ns < theta and x_i=1 => x_i^{t+1}=1 regardless of U_{t,i}."
    },
    {
      "id": "N3",
      "name": "empty_isolated_birth_only",
      "statement": "If a site is empty and neighbor-sum < theta, occupation at t+1 occurs iff U_{t,i} < p_birth.",
      "class": "NECESSARY",
      "justification": "Direct from the second branch of the transition rule."
    },
    {
      "id": "E1",
      "name": "high_exclusion_extinction_tendency",
      "statement": "Across wave-1 cells with theta=1 and r>=2, mean extinction_rate=0.000 (over seeds aggregated per cell).",
